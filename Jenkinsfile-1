pipeline {
    agent {
        node {
            label 'dockerhost-build-server'
        }
    }
    tools {
        maven 'maven'
    }
    // HEMOS QUITADO EL BLOQUE ENVIRONMENT QUE PEDÍA LA CREDENCIAL
    stages {
        stage('Packaging') {
            steps {
                echo 'Packaging..'
                sh 'mvn clean package'
            }
        }
        stage('Copying war file') {
            steps {
                echo 'Copying war file..'
                sh 'cp target/*.war .'
            }
        }
        stage('build image') {
            steps {
                echo 'Building image...'
                // Aquí solo construye la imagen en tu máquina local
                sh 'docker build -t davids884/devops-web-project:v1 --label devops-web-project-server .'
            }
        }
        // HEMOS QUITADO LOS STAGES DE 'Docker Hub Login' Y 'Push' 
        // Porque esos son los que necesitan la contraseña obligatoriamente.
    }
}
